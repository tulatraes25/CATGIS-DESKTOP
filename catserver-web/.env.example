# CATSERVER Web - Variables de entorno
# Copia este archivo como .env o defini las variables en el sistema operativo.

# Puerto donde escucha el servidor web (default: 3080)
CATSERVER_WEB_PORT=3080

# Datos de conexion a PostgreSQL/PostGIS
CATSERVER_DB_HOST=localhost
CATSERVER_DB_PORT=5432
CATSERVER_DB_NAME=catserver
CATSERVER_DB_USER=catserver_viewer_user
CATSERVER_DB_PASSWORD=

# Token API para proteger el acceso al visor (opcional, pero recomendado)
# Si se define, todas las requests a /api/* deben incluir el header X-API-Key con este valor
CATSERVER_WEB_API_KEY=
